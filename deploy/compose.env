# Default environment for `docker compose -f docker-compose.prod.yml`.
# Safe for local smoke tests only. For real deployments, override with secrets
# (e.g. copy to a gitignored file and point `env_file` there, or use your platform's secret store).

POSTGRES_USER=toothfairy
POSTGRES_PASSWORD=toothfairy
POSTGRES_DB=toothfairy

# Hostname `db` is the Compose service name (not localhost from inside the API container).
TOOTHFAIRY_DATABASE_URL=postgresql+asyncpg://toothfairy:toothfairy@db:5432/toothfairy

TOOTHFAIRY_CORS_ORIGINS=["http://localhost:3000"]
TOOTHFAIRY_AUTH_JWT_SECRET=local-docker-compose-only-change-me
TOOTHFAIRY_AUTH_DEV_LOGIN_ENABLED=false
TOOTHFAIRY_GUEST_COOKIE_SECURE=false
TOOTHFAIRY_GUEST_COOKIE_SAMESITE=lax
