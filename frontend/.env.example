# Local development: copy to `.env.local` (Next.js reads `NEXT_PUBLIC_*` at dev and build time).
# Production / Docker: pass as a build-arg `NEXT_PUBLIC_API_BASE_URL` (see ../Dockerfile.frontend).

# Public base URL of the FastAPI server (no trailing slash). Browsers and SSR use this to call the API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
