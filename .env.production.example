# Copy to `.env.production` at the repo root for real deployments (gitignored).
# Optional: set `env_file: - .env.production` on the `api` service in docker-compose.prod.yml
# instead of `deploy/compose.env`.
#
# Local Docker Compose uses tracked `deploy/compose.env` by default (smoke-test secrets only).

POSTGRES_USER=toothfairy
POSTGRES_PASSWORD=change-me
POSTGRES_DB=toothfairy

# Override DB URL only if not using the compose default (postgres service name `db`).
# TOOTHFAIRY_DATABASE_URL=postgresql+asyncpg://toothfairy:change-me@db:5432/toothfairy

TOOTHFAIRY_CORS_ORIGINS=["http://localhost:3000"]
TOOTHFAIRY_AUTH_JWT_SECRET=generate-a-long-random-secret
TOOTHFAIRY_AUTH_DEV_LOGIN_ENABLED=false
TOOTHFAIRY_GUEST_COOKIE_SECURE=false
TOOTHFAIRY_GUEST_COOKIE_SAMESITE=lax

# Optional: set true and use a CUDA base image / custom Dockerfile for GPU inference.
# INSTALL_ML=false
