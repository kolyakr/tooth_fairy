# Copy to `.env` at the repository root (pydantic loads `TOOTHFAIRY_*` from cwd) or export before Alembic / uvicorn.
# See also: ../docs/DEPLOYMENT.md and ../.env.production.example for Docker Compose.

# --- Database ---
TOOTHFAIRY_DATABASE_URL=postgresql+asyncpg://toothfairy:toothfairy@localhost:5432/toothfairy

# --- HTTP / CORS (JSON list of allowed browser origins) ---
TOOTHFAIRY_CORS_ORIGINS=["http://localhost:3000"]

# --- API metadata ---
# TOOTHFAIRY_PROJECT_NAME=ToothFairy API
# TOOTHFAIRY_API_V1_PREFIX=/api/v1
# TOOTHFAIRY_DEBUG=false

# --- JWT (persisted sessions; also used to sign guest cookies) ---
# TOOTHFAIRY_AUTH_JWT_SECRET=change-me-in-production
# TOOTHFAIRY_AUTH_JWT_ALGORITHM=HS256
# TOOTHFAIRY_AUTH_ACCESS_TOKEN_TTL_MINUTES=60
# Dev-only: POST /api/v1/auth/token — never enable in production
# TOOTHFAIRY_AUTH_DEV_LOGIN_ENABLED=false

# --- Guest session (unauthenticated uploads) ---
# TOOTHFAIRY_GUEST_SESSION_COOKIE_NAME=toothfairy_guest
# TOOTHFAIRY_GUEST_SESSION_TTL_SECONDS=86400
# TOOTHFAIRY_GUEST_MAX_ANALYSES_PER_SESSION=50
# Set true behind HTTPS in production
# TOOTHFAIRY_GUEST_COOKIE_SECURE=false
# lax | strict | none (none requires Secure + cross-site setup)
# TOOTHFAIRY_GUEST_COOKIE_SAMESITE=lax

# --- Repo / modeling paths ---
# TOOTHFAIRY_REPO_ROOT=/abs/path/to/repo
# TOOTHFAIRY_MODELING_ROOT=/abs/path/to/modeling

# --- YOLO weights (defaults under modeling/models/...) ---
# TOOTHFAIRY_MODEL_QUADRANTS_PATH=/abs/path/to/best.pt
# TOOTHFAIRY_MODEL_TEETH_PATH=/abs/path/to/best.pt
# TOOTHFAIRY_MODEL_PERIAPICAL_PATH=/abs/path/to/best.pt
# TOOTHFAIRY_MODEL_TEETH_CLASSIFICATION_PATH=/abs/path/to/best.pt

# --- Inference confidence thresholds (0–1) ---
# TOOTHFAIRY_CONF_QUADRANTS=0.3
# TOOTHFAIRY_CONF_TEETH=0.3
# TOOTHFAIRY_CONF_PERIAPICAL=0.3
# TOOTHFAIRY_CONF_TEETH_CLASSIFICATION=0.3
