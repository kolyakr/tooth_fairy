            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer\": \"Dr. Nick\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/analyses/{{analysisId}}/complete-review"
          }
