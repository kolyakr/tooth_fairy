              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer\": \"Dr. Nick\",\n  \"action\": \"Checked findings in Postman\",\n  \"action_type\": \"system\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/analyses/{{analysisId}}/audit"
